{
  "name": "@codeinklingon/browser-mcp",
  "version": "0.1.0",
  "description": "MCP server for headless browser automation (Puppeteer-based)",
  "type": "module",
  "bin": {
    "browser-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "node scripts/generate-assets.mjs",
    "build": "npm run generate && node scripts/build.mjs",
    "prepublishOnly": "npm run build",
    "start": "tsx src/index.ts",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "@puppeteer/browsers": "^2.8.0",
    "puppeteer-core": "^24.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codeinklingon/browser-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
